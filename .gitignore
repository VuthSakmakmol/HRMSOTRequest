node_modules/
backend/node_modules/
frontend/node_modules/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# build
dist/
build/
coverage/
.vite/
.cache/
frontend/dist/
backend/dist/

# temp / uploads / exports
tmp/
temp/
uploads/
storage/
backend/tmp/
backend/temp/
backend/uploads/
backend/storage/
backend/public/uploads/
backend/public/export/
backend/public/exports/

# editor / os
.vscode/
.idea/
.DS_Store
Thumbs.db

# keys / certs
*.pem
*.key
*.crt
*.pfx
*.p12